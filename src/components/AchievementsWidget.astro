---
interface Achievement {
  icon: string;
  number: string;
  label: string;
}

const achievements: Achievement[] = [
  {
    icon: "",
    number: "12+",
    label: "Projects Complete"
  },
  {
    icon: "",
    number: "60+",
    label: "Labor Hours Saved"
  },
  {
    icon: "",
    number: "7+",
    label: "Certifications Complete"
  }
];
---

<div class="bg-gradient-to-r from-blue-600 to-blue-800 rounded-3xl p-8 shadow-xl text-white">
  <div class="grid grid-cols-3 gap-8">
    {achievements.map((achievement) => (
      <div class="text-center">
        <p class="text-4xl font-bold mb-1">{achievement.number}</p>
        <p class="text-blue-100 text-sm">{achievement.label}</p>
      </div>
    ))}
  </div>
</div>
