---
interface Achievement {
  number: string;
  label: string;
}

const achievements: Achievement[] = [
  {
    number: "12+",
    label: "Projects Delivered"
  },
  {
    number: "800+",
    label: "Hours Saved Annually"
  },
  {
    number: "9+",
    label: "Certifications Complete"
  }
];
---

<div class="bg-gradient-to-r from-blue-600 to-blue-800 rounded-2xl p-4 shadow-xl text-white hover:-translate-y-1 hover:shadow-2xl transition-all duration-300">
  <div class="grid grid-cols-3 gap-4">
    {achievements.map((achievement) => (
      <div class="text-center">
        <p class="text-2xl font-bold mb-0.5">{achievement.number}</p>
        <p class="text-blue-100 text-xs">{achievement.label}</p>
      </div>
    ))}
  </div>
</div>
