---
interface Achievement {
  number: string;
  label: string;
}

const achievements: Achievement[] = [
  {
    number: "12+",
    label: "Projects Delivered"
  },
  {
    number: "800+",
    label: "Manual Hours Saved Annually"
  },
  {
    number: "9+",
    label: "Certifications Complete"
  }
];
---

<div class="bg-gradient-to-r from-blue-600 to-blue-800 rounded-2xl p-4 shadow-xl text-white hover:-translate-y-1 hover:shadow-2xl transition-all duration-300">
  <div class="grid grid-cols-4 gap-4 items-center">
    {achievements.map((achievement) => (
      <div class="text-center">
        <p class="text-2xl font-bold mb-0.5">{achievement.number}</p>
        <p class="text-blue-100 text-xs">{achievement.label}</p>
      </div>
    ))}
    <!-- Contact column -->
    <div class="text-center border-l border-white/30 pl-4 flex flex-col items-center justify-center">
      <div class="flex justify-center gap-3 mb-2">
          <a href="mailto:ivanajns@gmail.com" target="_blank" rel="noopener noreferrer" class="text-white hover:text-blue-900 transition-colors">
            <span class="sr-only">Email</span>
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M1.5 8.67v8.58a3 3 0 003 3h15a3 3 0 003-3V8.67l-8.928 5.493a3 3 0 01-3.144 0L1.5 8.67z" />
              <path d="M22.5 6.908V6.75a3 3 0 00-3-3h-15a3 3 0 00-3 3v.158l9.714 5.978a1.5 1.5 0 001.572 0L22.5 6.908z" />
            </svg>
          </a>
          <a href="https://www.linkedin.com/in/ivanajns" target="_blank" rel="noopener noreferrer" class="text-white hover:text-blue-900 transition-colors">
            <span class="sr-only">LinkedIn</span>
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd" />
            </svg>
          </a>
          <a href="tel:+18647046234" class="text-white hover:text-blue-900 transition-colors">
            <span class="sr-only">Phone</span>
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M1.5 4.5a3 3 0 013-3h1.372c.86 0 1.61.586 1.819 1.42l1.105 4.423a1.875 1.875 0 01-.694 1.955l-1.293.97c-.135.101-.164.249-.126.352a11.285 11.285 0 006.697 6.697c.103.038.25.009.352-.126l.97-1.293a1.875 1.875 0 011.955-.694l4.423 1.105c.834.209 1.42.959 1.42 1.82V19.5a3 3 0 01-3 3h-2.25C8.552 22.5 1.5 15.448 1.5 6.75V4.5z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>
      <p class="text-xs text-blue-100">Contact</p>
    </div>
  </div>
</div>
