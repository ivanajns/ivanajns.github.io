---
interface Achievement {
  icon: string;
  number: string;
  label: string;
}

const achievements: Achievement[] = [
  {
    icon: "",
    number: "12+",
    label: "Projects Delivered"
  },
  {
    icon: "",
    number: "800+",
    label: "Manual Hours Saved Annually"
  },
  {
    icon: "",
    number: "9+",
    label: "Certifications Complete"
  }
];
---

<div class="bg-[#2C2C2E] rounded-2xl p-4 shadow-sm text-white">
  <div class="grid grid-cols-3 gap-4">
    {achievements.map((achievement) => (
      <div class="text-center">
        <p class="text-2xl font-bold mb-0.5">{achievement.number}</p>
        <p class="text-[#A1A1A6] text-xs">{achievement.label}</p>
      </div>
    ))}
  </div>
</div>
