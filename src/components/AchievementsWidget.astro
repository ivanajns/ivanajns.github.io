---
interface Achievement {
  icon: string;
  number: string;
  label: string;
}

const achievements: Achievement[] = [
  {
    icon: "",
    number: "12+",
    label: "Projects Delivered"
  },
  {
    icon: "",
    number: "800+",
    label: "Manual Hours Saved Annually"
  },
  {
    icon: "",
    number: "9+",
    label: "Certifications Complete"
  }
];
---

<div class="relative overflow-hidden bg-gradient-to-r from-blue-400 to-blue-900 rounded-2xl p-4 shadow-lg text-white hover:-translate-y-1 hover:shadow-2xl transition-all duration-300">
  <!-- Shimmer overlay -->
  <div class="absolute inset-0 bg-gradient-to-br from-white/20 via-white/5 to-transparent rounded-2xl pointer-events-none"></div>
  <div class="relative grid grid-cols-3 gap-4">
    {achievements.map((achievement) => (
      <div class="text-center">
        <p class="text-2xl font-bold mb-0.5">{achievement.number}</p>
        <p class="text-blue-100 text-xs">{achievement.label}</p>
      </div>
    ))}
  </div>
</div>
