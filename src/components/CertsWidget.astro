---
import { certs } from "../data/certs";
---

<div class="bg-white/80 backdrop-blur-lg rounded-3xl p-6 shadow-xl border border-white/60 hover:-translate-y-1 hover:shadow-2xl transition-all duration-300">
  <div class="mb-6 pb-4 border-b border-blue-100">
    <h3 class="text-2xl font-semibold text-blue-900 tracking-wide">Featured Certifications</h3>
  </div>
  <div class="grid gap-4">
    {certs.map((cert) => (
      <a
        href={cert.url}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-4 bg-gradient-to-br from-blue-50 to-white p-4 rounded-2xl hover:shadow-lg transition-all duration-300 group"
      >
        <img
          src={cert.image}
          alt={cert.title}
          class="w-16 h-16 rounded-xl object-cover flex-shrink-0"
        />
        <div class="flex-1 min-w-0">
          <h4 class="text-base font-medium text-blue-600 group-hover:text-blue-800 transition-colors leading-snug mb-3">
            {cert.title}
          </h4>
          <div class="flex flex-wrap gap-1">
            {cert.tags.map((tag) => (
              <span class="px-2 py-0.5 bg-blue-100 text-blue-900 rounded-full text-xs">{tag}</span>
            ))}
          </div>
        </div>
        <div class="flex-shrink-0 text-blue-300 group-hover:text-blue-500 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
          </svg>
        </div>
      </a>
    ))}
  </div>
</div>
