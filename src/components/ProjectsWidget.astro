---
import { projects } from "../data/project";
import ProjectsGrid from "./ProjectsGrid";
---

<div class="bg-white/80 backdrop-blur-lg rounded-3xl p-6 shadow-xl">
  <div class="md:flex justify-between items-center mb-6">
    <h3 class="text-2xl font-semibold text-blue-900">Featured Projects</h3>
    <a href="/projects" class="text-blue-600 hover:text-blue-800 transition-colors text-sm">
      View more →
    </a>
  </div>
  <ProjectsGrid client:load projects={projects} />
</div>
