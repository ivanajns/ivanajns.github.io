---
import { projects } from "./Projects";
import ProjectsGrid from "./ProjectsGrid";
---

<div class="bg-white/80 backdrop-blur-lg rounded-3xl p-6 shadow-xl h-full border border-white/60 hover:-translate-y-1 hover:shadow-2xl transition-all duration-300">
  <div class="mb-6 pb-4 border-b border-blue-100">
    <h3 class="text-2xl font-semibold text-blue-900 tracking-wide">Featured Projects</h3>
  </div>
  <ProjectsGrid client:load projects={projects} />
</div>
