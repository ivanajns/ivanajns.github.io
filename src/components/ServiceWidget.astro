---
interface Service {
  title: string;
  company: string;
  companyUrl: string;
  period: string;
  description: string[];
}

interface Award {
  degree: string;
  school: string;
  schoolUrl: string;
  period: string;
  achievements: string[];
}

const services: Service[] = [
  {
    title: "Founder",
    company: "Career Cheat Sheets",
    companyUrl: "https://beacons.ai/careercheatsheets",
    period: "",
    description: [
      "Founded and led a nonprofit initiative that empowered 150+ youth over two years through community partnerships, delivering a five-part career development curriculum built around the guidance I wish I had as a student."
    ]
  },
  {
    title: "Finance Committee Lead",
    company: "First Gen Success",
    companyUrl: "https://www.firstgensuccess.org",
    period: "",
    description: [
      "As a first-generation student, serving on the Finance Committee of First Gen Success for two years was both personal and purposeful. I provided financial reporting support to strengthen operations and ensure continued impact for the students this organization serves."
    ]
  },
  {
    title: "Mentorship Under a Director",
    company: "Charlotte Young Professionals Group",
    companyUrl: "https://www.cypg.org",
    period: "",
    description: [
      "Completed a year-long structured mentorship under a Director through the Charlotte Young Professionals Group. I developed stronger leadership discernment around when to ask for help, when to hold boundaries, and when to let others own their outcomes."
    ]
  }
];

const awards: Award[] = [
  {
    degree: "Next Tech Award",
    school: "North Carolina Technology Association",
    schoolUrl: "https://www.nctech.org/events/Awards/next-tech-awards-winners-2025.html",
    period: "2025",
    achievements: [
      "Selected as a Next Tech Award winner by the North Carolina Technology Association in partnership with Business North Carolina, recognizing rising tech talent making meaningful contributions to their organizations and communities across the state."
    ]
  },
  {
    degree: "Black Women in Tech Feature",
    school: "Global Tech Advocates",
    schoolUrl: "https://theblackwomenintech.com/the-voices-in-the-shadow-project-2/",
    period: "",
    achievements: [
      "Featured in Global Tech Advocates' Black Women in Tech, sharing an unconventional path into tech and lessons learned along the way to help promote diversity and inclusion in the workplace."
    ]
  },
  {
    degree: "Top 30 Under 30 Future Leaders of Charlotte Award",
    school: "Elevate Lifestyle",
    schoolUrl: "https://www.newsbreak.com/event/68ba7c7a0ce011ae46e1d483-top-30-under-30-future-leaders-of-charlotte-class-of-2025",
    period: "2025",
    achievements: [
      "Named to Charlotte's Top 30 Under 30 Class of 2025, recognizing young professionals making a meaningful impact in their profession and community."
    ]
  }
];
---

<div class="space-y-8">
  <!-- Leadership & Service -->
  <div id="leadership" class="bg-white/80 backdrop-blur-lg rounded-3xl p-6 shadow-xl border border-white/60 hover:-translate-y-1 hover:shadow-2xl transition-all duration-300">
    <h3 class="text-2xl font-semibold text-blue-900 mb-4 pb-4 border-b border-blue-100 tracking-wide">Leadership & Service</h3>
    <div class="space-y-6">
      {services.map((service) => (
        <div class="bg-gradient-to-br from-blue-50 to-white p-4 rounded-2xl hover:shadow-lg transition-all duration-300">
          <div class="mb-2">
            <h4 class="text-base font-medium text-blue-600 mb-1">{service.title}</h4>
            <a href={service.companyUrl} target="_blank" rel="noopener noreferrer" class="text-sm text-blue-600/70 hover:text-blue-800 transition-colors">
              {service.company}
            </a>
          </div>
          <div class="text-apple-gray-400 text-base leading-relaxed space-y-1">
            {service.description.map((item) => (
              <p>{item}</p>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Chevron toggle -->
    <div class="flex justify-center pt-2">
      <button id="service-chevron" class="text-blue-600 hover:text-blue-800 transition-colors" aria-label="Toggle photos">
        <svg id="service-chevron-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 transition-transform duration-300">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
        </svg>
      </button>
    </div>

    <!-- Collapsible images -->
    <div id="service-images" class="overflow-hidden transition-all duration-500" style="max-height: 0;">
      <div class="flex flex-col sm:flex-row gap-4 pt-4">
        <button data-modal-img="/img/service-1.jpg" data-modal-target="service-modal" class="flex-1 h-96 cursor-pointer">
          <img
            src="/img/service-1.jpg"
            alt="Leadership & Service photo 1"
            class="w-full h-full object-cover object-center rounded-2xl bg-apple-gray-100 hover:opacity-90 transition-opacity"
            onerror="this.style.background='#e5e7eb'"
          />
        </button>
        <button data-modal-img="/img/service-2.jpg" data-modal-target="service-modal" class="flex-1 h-96 cursor-pointer">
          <img
            src="/img/service-2.jpg"
            alt="Leadership & Service photo 2"
            class="w-full h-full object-cover object-right rounded-2xl bg-apple-gray-100 hover:opacity-90 transition-opacity"
            onerror="this.style.background='#e5e7eb'"
          />
        </button>
      </div>
    </div>
  </div>

  <!-- Honors & Awards -->
  <div id="awards" class="bg-white/80 backdrop-blur-lg rounded-3xl p-6 shadow-xl border border-white/60 hover:-translate-y-1 hover:shadow-2xl transition-all duration-300">
    <h3 class="text-2xl font-semibold text-blue-900 mb-4 pb-4 border-b border-blue-100 tracking-wide">Honors & Awards</h3>
    <div class="space-y-6">
      {awards.map((award) => (
        <div class="bg-gradient-to-br from-blue-50 to-white p-4 rounded-2xl hover:shadow-lg transition-all duration-300">
          <div class="mb-2">
            <h4 class="text-base font-medium text-blue-600 mb-1">{award.degree}</h4>
            <a href={award.schoolUrl} target="_blank" rel="noopener noreferrer" class="text-sm text-blue-600/70 hover:text-blue-800 transition-colors">
              {award.school}
            </a>
          </div>
          <div class="text-apple-gray-400 text-base leading-relaxed space-y-1">
            {award.achievements.map((achievement) => (
              <p>{achievement}</p>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Chevron toggle -->
    <div class="flex justify-center pt-2">
      <button id="awards-chevron" class="text-blue-600 hover:text-blue-800 transition-colors" aria-label="Toggle photos">
        <svg id="awards-chevron-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 transition-transform duration-300">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
        </svg>
      </button>
    </div>

    <!-- Collapsible images -->
    <div id="awards-images" class="overflow-hidden transition-all duration-500" style="max-height: 0;">
      <div class="flex flex-col sm:flex-row gap-4 pt-4">
        <button data-modal-img="/img/awards-1.jpg" data-modal-target="awards-modal" class="flex-1 h-96 cursor-pointer">
          <img
            src="/img/awards-1.jpg"
            alt="Honors & Awards photo 1"
            class="w-full h-full object-cover object-center rounded-2xl bg-apple-gray-100 hover:opacity-90 transition-opacity"
            onerror="this.style.background='#e5e7eb'"
          />
        </button>
        <button data-modal-img="/img/awards-2.jpg" data-modal-target="awards-modal" class="flex-1 h-96 cursor-pointer">
          <img
            src="/img/awards-2.jpg"
            alt="Honors & Awards photo 2"
            class="w-full h-full object-cover object-left rounded-2xl bg-apple-gray-100 hover:opacity-90 transition-opacity"
            onerror="this.style.background='#e5e7eb'"
          />
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Leadership & Service modal -->
<div id="service-modal" class="fixed inset-0 z-50 hidden overflow-y-auto">
  <div id="service-modal-backdrop" class="fixed inset-0 bg-black/70 backdrop-blur-sm"></div>
  <div class="flex min-h-full items-center justify-center p-4">
    <div class="relative z-10 max-w-4xl w-full">
      <button id="service-modal-close" class="absolute top-3 right-3 z-20 w-9 h-9 flex items-center justify-center bg-black/60 hover:bg-black/80 rounded-full text-white transition-colors" aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
      <img id="service-modal-img" src="" alt="" class="w-full h-auto rounded-2xl shadow-2xl block" />
    </div>
  </div>
</div>

<!-- Honors & Awards modal -->
<div id="awards-modal" class="fixed inset-0 z-50 hidden overflow-y-auto">
  <div id="awards-modal-backdrop" class="fixed inset-0 bg-black/70 backdrop-blur-sm"></div>
  <div class="flex min-h-full items-center justify-center p-4">
    <div class="relative z-10 max-w-4xl w-full">
      <button id="awards-modal-close" class="absolute top-3 right-3 z-20 w-9 h-9 flex items-center justify-center bg-black/60 hover:bg-black/80 rounded-full text-white transition-colors" aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
      <img id="awards-modal-img" src="" alt="" class="w-full h-auto rounded-2xl shadow-2xl block" />
    </div>
  </div>
</div>

<script>
  // Escape GSAP transform stacking context
  document.body.appendChild(document.getElementById('service-modal')!);
  document.body.appendChild(document.getElementById('awards-modal')!);

  // Chevron expand/collapse
  function setupChevron(chevronId: string, iconId: string, imagesId: string) {
    const chevron = document.getElementById(chevronId)!;
    const icon = document.getElementById(iconId)!;
    const images = document.getElementById(imagesId)!;
    let isOpen = false;

    chevron.addEventListener('click', () => {
      isOpen = !isOpen;
      if (isOpen) {
        images.style.maxHeight = images.scrollHeight + 'px';
        icon.style.transform = 'rotate(180deg)';
      } else {
        images.style.maxHeight = '0';
        icon.style.transform = 'rotate(0deg)';
      }
    });
  }

  setupChevron('service-chevron', 'service-chevron-icon', 'service-images');
  setupChevron('awards-chevron', 'awards-chevron-icon', 'awards-images');

  // Modal setup
  function setupModal(modalId: string) {
    const modal = document.getElementById(modalId)!;
    const modalImg = document.getElementById(`${modalId}-img`) as HTMLImageElement;
    const backdrop = document.getElementById(`${modalId}-backdrop`)!;
    const closeBtn = document.getElementById(`${modalId}-close`)!;

    function closeModal() {
      modal.classList.add('hidden');
      document.body.style.overflow = '';
    }

    backdrop.addEventListener('click', closeModal);
    closeBtn.addEventListener('click', closeModal);

    return { modal, modalImg };
  }

  const { modal: serviceModal, modalImg: serviceImg } = setupModal('service-modal');
  const { modal: awardsModal, modalImg: awardsImg } = setupModal('awards-modal');

  document.querySelectorAll<HTMLButtonElement>('[data-modal-img]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const src = btn.dataset.modalImg!;
      const alt = btn.querySelector('img')?.alt || '';
      const targetId = btn.dataset.modalTarget!;

      if (targetId === 'service-modal') {
        serviceImg.src = src;
        serviceImg.alt = alt;
        serviceModal.classList.remove('hidden');
      } else if (targetId === 'awards-modal') {
        awardsImg.src = src;
        awardsImg.alt = alt;
        awardsModal.classList.remove('hidden');
      }
      document.body.style.overflow = 'hidden';
    });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      serviceModal.classList.add('hidden');
      awardsModal.classList.add('hidden');
      document.body.style.overflow = '';
    }
  });
</script>
