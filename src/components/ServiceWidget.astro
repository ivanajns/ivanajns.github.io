---
interface Service {
  title: string;
  company: string;
  companyUrl: string;
  period: string;
  description: string[];
}

interface Award {
  degree: string;
  school: string;
  schoolUrl: string;
  period: string;
  achievements: string[];
}

const services: Service[] = [
  {
    title: "Founder",
    company: "Career Cheat Sheets",
    companyUrl: "https://beacons.ai/careercheatsheets",
    period: "",
    description: [
      "Career Cheat Sheets is my nonprofit community initiative where I created and delivered a five-part career development series covering the knowledge and lessons I wish I had access to as a student. Through community organization partnerships, this work has supported and empowered more than 150 youth to navigate their careers confidently."
    ]
  },
  {
    title: "Finance Committee Volunteer",
    company: "First Gen Success",
    companyUrl: "https://www.firstgensuccess.org",
    period: "",
    description: [
      "First Gen Success is a cause that is personal to me, shaped by my own experience as a first-generation student. I volunteer on the Finance Committee, providing financial reporting support to help strengthen the organization's operations and ensure continued impact for students as they pursue opportunities that once felt out of reach."
    ]
  },
  {
    title: "Mentorship Under a Director",
    company: "Charlotte Young Professionals Group",
    companyUrl: "https://www.cypg.org",
    period: "",
    description: [
      "Charlotte Young Professionals Group is a regional organization focused on professional development and networking within the Charlotte community. I participated in a year-long, structured mentorship under a Director, gaining valuable perspective on leadership, career growth, and navigating professional environments."
    ]
  }
];

const awards: Award[] = [
  {
    degree: "Next Tech Award",
    school: "North Carolina Technology Association",
    schoolUrl: "https://www.nctech.org/events/Awards/next-tech-awards-winners-2025.html",
    period: "2025",
    achievements: [
      "I'm honored that I was selected as a Next Tech Award winner by the North Carolina Technology Association in partnership with Business North Carolina. The award recognizes rising tech talent making meaningful contributions to their organizations and communities across the state."
    ]
  },
  {
    degree: "Black Women in Tech Feature",
    school: "Global Tech Advocates",
    schoolUrl: "https://theblackwomenintech.com/the-voices-in-the-shadow-project-2/",
    period: "",
    achievements: [
      "I was selected to share my unconventional story and lessons learned in a feature by Global Tech Advocate's Black Women in Tech, a not-for-profit network that aims to support Black women in technology and help companies perform better through diversity and inclusion."
    ]
  },
  {
    degree: "Top 30 Under 30 Future Leaders of Charlotte Award",
    school: "Elevate Lifestyle",
    schoolUrl: "https://www.newsbreak.com/event/68ba7c7a0ce011ae46e1d483-top-30-under-30-future-leaders-of-charlotte-class-of-2025",
    period: "2025",
    achievements: [
      "I'm honored to be named among Charlotte's Top 30 Under 30 Class of 2025, an award that celebrates young professionals making a meaningful impact in leadership and the community. Being recognized among people who uplift our community is truly inspiring."
    ]
  }
];
---

<div class="space-y-8">
  <div id="leadership" class="bg-white/80 backdrop-blur-lg rounded-3xl p-6 shadow-xl">
    <h3 class="text-2xl font-semibold text-blue-900 mb-4">Leadership & Service</h3>
    <div class="flex flex-col md:flex-row gap-6 mb-6">
      <div class="flex-1 space-y-6">
      {services.map((service) => (
        <div class="border-l-2 border-blue-500 pl-4 pb-6">
          <div class="flex flex-col sm:flex-row justify-between items-start gap-2 mb-4">
            <div>
              <h4 class="text-xl font-medium text-apple-gray-500">{service.title}</h4>
              <a href={service.companyUrl} target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:text-blue-800 transition-colors">
                {service.company}
              </a>
            </div>
            {service.period && (
              <span class="text-sm text-apple-gray-300 bg-apple-gray-100 px-3 py-1 rounded-full whitespace-nowrap">
                {service.period}
              </span>
            )}
          </div>
          <div class="text-apple-gray-400 mb-3 space-y-1">
            {service.description.map((item) => (
              <p>{item}</p>
            ))}
          </div>
        </div>
      ))}
      </div>
      <div class="flex flex-col gap-4 w-full md:w-80 flex-shrink-0 md:self-stretch">
        <button data-modal-img="/img/service-1.jpg" data-modal-target="service-modal" class="h-48 md:flex-1 md:min-h-0 cursor-pointer">
          <img
            src="/img/service-1.jpg"
            alt="Leadership & Service photo 1"
            class="w-full h-full object-cover object-center rounded-2xl bg-apple-gray-100 hover:opacity-90 transition-opacity"
            onerror="this.style.background='#e5e7eb'"
          />
        </button>
        <button data-modal-img="/img/service-2.jpg" data-modal-target="service-modal" class="h-48 md:flex-1 md:min-h-0 cursor-pointer">
          <img
            src="/img/service-2.jpg"
            alt="Leadership & Service photo 2"
            class="w-full h-full object-cover object-right rounded-2xl bg-apple-gray-100 hover:opacity-90 transition-opacity"
            onerror="this.style.background='#e5e7eb'"
          />
        </button>
      </div>
    </div>
  </div>

  <div id="awards" class="bg-white/80 backdrop-blur-lg rounded-3xl p-6 shadow-xl">
    <h3 class="text-2xl font-semibold text-blue-900 mb-4">Honors & Awards</h3>
    <div class="flex flex-col md:flex-row gap-6 mb-6">
      <div class="flex-1 space-y-6">
      {awards.map((award) => (
        <div class="border-l-2 border-blue-500 pl-4 pb-6">
          <div class="flex flex-col sm:flex-row justify-between items-start gap-2 mb-4">
            <div>
              <h4 class="text-xl font-medium text-apple-gray-500">{award.degree}</h4>
              <a href={award.schoolUrl} target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:text-blue-800 transition-colors">
                {award.school}
              </a>
            </div>
          </div>
          <div class="text-apple-gray-400 space-y-1">
            {award.achievements.map((achievement) => (
              <p>{achievement}</p>
            ))}
          </div>
        </div>
      ))}
      </div>
      <div class="flex flex-col gap-4 w-full md:w-80 flex-shrink-0 md:self-stretch">
        <button data-modal-img="/img/awards-1.jpg" data-modal-target="awards-modal" class="h-48 md:flex-1 md:min-h-0 cursor-pointer">
          <img
            src="/img/awards-1.jpg"
            alt="Honors & Awards photo 1"
            class="w-full h-full object-cover object-center rounded-2xl bg-apple-gray-100 hover:opacity-90 transition-opacity"
            onerror="this.style.background='#e5e7eb'"
          />
        </button>
        <button data-modal-img="/img/awards-2.jpg" data-modal-target="awards-modal" class="h-48 md:flex-1 md:min-h-0 cursor-pointer">
          <img
            src="/img/awards-2.jpg"
            alt="Honors & Awards photo 2"
            class="w-full h-full object-cover object-left rounded-2xl bg-apple-gray-100 hover:opacity-90 transition-opacity"
            onerror="this.style.background='#e5e7eb'"
          />
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Leadership & Service modal -->
<div id="service-modal" class="fixed inset-0 z-50 hidden overflow-y-auto">
  <div id="service-modal-backdrop" class="fixed inset-0 bg-black/70 backdrop-blur-sm"></div>
  <div class="flex min-h-full items-center justify-center p-4">
    <div class="relative z-10 max-w-4xl w-full">
      <button id="service-modal-close" class="absolute top-3 right-3 z-20 w-9 h-9 flex items-center justify-center bg-black/60 hover:bg-black/80 rounded-full text-white transition-colors" aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
      <img id="service-modal-img" src="" alt="" class="w-full h-auto rounded-2xl shadow-2xl block" />
    </div>
  </div>
</div>

<!-- Honors & Awards modal -->
<div id="awards-modal" class="fixed inset-0 z-50 hidden overflow-y-auto">
  <div id="awards-modal-backdrop" class="fixed inset-0 bg-black/70 backdrop-blur-sm"></div>
  <div class="flex min-h-full items-center justify-center p-4">
    <div class="relative z-10 max-w-4xl w-full">
      <button id="awards-modal-close" class="absolute top-3 right-3 z-20 w-9 h-9 flex items-center justify-center bg-black/60 hover:bg-black/80 rounded-full text-white transition-colors" aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
      <img id="awards-modal-img" src="" alt="" class="w-full h-auto rounded-2xl shadow-2xl block" />
    </div>
  </div>
</div>

<script>
  function setupModal(modalId: string) {
    const modal = document.getElementById(modalId)!;
    const modalImg = document.getElementById(`${modalId}-img`) as HTMLImageElement;
    const backdrop = document.getElementById(`${modalId}-backdrop`)!;
    const closeBtn = document.getElementById(`${modalId}-close`)!;

    function closeModal() {
      modal.classList.add('hidden');
      document.body.style.overflow = '';
    }

    backdrop.addEventListener('click', closeModal);
    closeBtn.addEventListener('click', closeModal);

    return { modal, modalImg, closeModal };
  }

  // Escape GSAP transform stacking context — same fix as React createPortal
  document.body.appendChild(document.getElementById('service-modal')!);
  document.body.appendChild(document.getElementById('awards-modal')!);

  const { modal: serviceModal, modalImg: serviceImg } = setupModal('service-modal');
  const { modal: awardsModal, modalImg: awardsImg } = setupModal('awards-modal');

  document.querySelectorAll<HTMLButtonElement>('[data-modal-img]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const src = btn.dataset.modalImg!;
      const alt = btn.querySelector('img')?.alt || '';
      const targetId = btn.dataset.modalTarget!;

      if (targetId === 'service-modal') {
        serviceImg.src = src;
        serviceImg.alt = alt;
        serviceModal.classList.remove('hidden');
      } else if (targetId === 'awards-modal') {
        awardsImg.src = src;
        awardsImg.alt = alt;
        awardsModal.classList.remove('hidden');
      }
      document.body.style.overflow = 'hidden';
    });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      serviceModal.classList.add('hidden');
      awardsModal.classList.add('hidden');
      document.body.style.overflow = '';
    }
  });
</script>
