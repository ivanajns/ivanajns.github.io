---
import Layout from '../layouts/Layout.astro'
import Hero from '../components/Hero.astro'
import InfoWidgets from '../components/InfoWidgets.astro'
import AchievementsWidget from '../components/AchievementsWidget.astro'
import AboutWidget from '../components/AboutWidget.astro'
import ProjectsWidget from '../components/ProjectsWidget.astro'
import ServiceWidget from '../components/ServiceWidget.astro'
import BlogWidgets from '../components/BlogWidgets.astro'
import CertsWidget from '../components/CertsWidget.astro'
import ContactCard from '../components/ContactCard.astro'
import LocationCard from '../components/LocationCard.astro'
---

<Layout title="Ivana Jones — Senior BI Developer & Community Builder">
  <main>
    <Hero />

    <section class="py-20 px-4">
      <div class="container mx-auto max-w-6xl">
        <div class="mb-8" data-animate>
          <InfoWidgets />
        </div>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8 items-stretch" data-animate>
          <div class="md:col-span-2"><AchievementsWidget /></div>
          <div class="md:col-span-1"><LocationCard /></div>
          <div class="md:col-span-1"><ContactCard /></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8" data-animate>
          <div id="about"><AboutWidget /></div>
          <BlogWidgets />
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8" data-animate>
          <div id="portfolio"><ProjectsWidget /></div>
          <CertsWidget />
        </div>
        <div class="space-y-8 mb-8" data-animate>
          <ServiceWidget />
        </div>
      </div>
    </section>
  </main>
</Layout>
